{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/book", "destination": "/book.html" },
    { "source": "/apply", "destination": "/apply.html" },
    { "source": "/operator", "destination": "/operator.html" },
    { "source": "/operator/login", "destination": "/operator-login.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/login", "destination": "/admin-login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
